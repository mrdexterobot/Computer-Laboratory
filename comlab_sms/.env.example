DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_SCHEMA=comlab
DEPARTMENT_INTEGRATION_SHARED_TOKEN=replace-with-a-long-random-token

# Same Supabase project as HR and PMED (PostgREST). Required for “Request employee from HR” on scheduling.
# Use the same values as VITE_SUPABASE_URL and VITE_SUPABASE_PUBLISHABLE_KEY (or anon key) in HR/.env.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-or-publishable-key>
